# SourceBox Sentry CloudNode Configuration
# Copy this file to .env and fill in your values

# Required: Node ID from SourceBox Sentry Command Center Settings
SOURCEBOX_SENTRY_NODE_ID=

# Required: API Key from SourceBox Sentry Command Center Settings
SOURCEBOX_SENTRY_API_KEY=org_sk_your_api_key_here

# Required: Command Center URL
SOURCEBOX_SENTRY_API_URL=http://localhost:8000

# Optional: Override config file location
# SOURCEBOX_SENTRY_CONFIG=/etc/sourcebox-sentry/config.yaml

# Optional: Log level (trace, debug, info, warn, error)
RUST_LOG=info