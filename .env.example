# OpenSentry CloudNode Configuration
# Copy this file to .env and fill in your values

# Required: Node ID from OpenSentry Command Center Settings
OPENSENTRY_NODE_ID=

# Required: API Key from OpenSentry Command Center Settings
OPENSENTRY_API_KEY=org_sk_your_api_key_here

# Required: Command Center URL
OPENSENTRY_API_URL=http://localhost:8000

# Optional: Override config file location
# OPENSENTRY_CONFIG=/etc/opensentry/config.yaml

# Optional: Log level (trace, debug, info, warn, error)
RUST_LOG=info